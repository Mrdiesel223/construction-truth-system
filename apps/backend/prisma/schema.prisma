generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  FIELD_STAFF
  MANAGER
}

enum AttendanceType {
  START_DAY
  END_DAY
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  PAUSED
  COMPLETED
  SKIPPED
}

model User {
  id         Int          @id @default(autoincrement())
  email      String       @unique
  phone      String?      @unique
  password   String
  name       String
  role       Role         @default(FIELD_STAFF)
  attendance Attendance[]
  visits     Visit[]
  tasks      Task[]       @relation("AssignedWorkers")
  taskLogs   TaskLog[]
  media      Media[]
  locations  Location[]
  events     Event[]
  alerts     Alert[]
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
}

model Site {
  id        Int      @id @default(autoincrement())
  name      String
  address   String?
  lat       Float
  lng       Float
  radius    Float    @default(500)
  zones     Zone[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Zone {
  id        Int      @id @default(autoincrement())
  siteId    Int
  site      Site     @relation(fields: [siteId], references: [id])
  name      String
  lat       Float
  lng       Float
  radius    Float    @default(50) // Internal site zones
  cameraId  String?  // AI/Camera Integration placeholder
  tasks     Task[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Attendance {
  id        Int            @id @default(autoincrement())
  userId    Int
  user      User           @relation(fields: [userId], references: [id])
  type      AttendanceType
  lat       Float
  lng       Float
  timestamp DateTime       @default(now())
  createdAt DateTime       @default(now())
}

model Task {
  id               Int       @id @default(autoincrement())
  title            String
  description      String?
  zoneId           Int
  zone             Zone      @relation(fields: [zoneId], references: [id])
  
  // EXPECTATION LAYER
  expectedStartTime DateTime?
  expectedEndTime   DateTime?
  expectedDuration  Int?      // In minutes
  expectedFrequency String?   // e.g., "Daily", "Every 2 Hours"
  
  status           TaskStatus @default(PENDING)
  assignedWorkers  User[]    @relation("AssignedWorkers")
  logs             TaskLog[]
  events           Event[]
  media            Media[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model TaskLog {
  id        Int      @id @default(autoincrement())
  taskId    Int
  task      Task     @relation(fields: [taskId], references: [id])
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  type      String   // "WORK", "PAUSE"
  startTime DateTime @default(now())
  endTime   DateTime?
  duration  Int?     // In minutes
  createdAt DateTime @default(now())
}

model Event {
  id        Int      @id @default(autoincrement())
  type      String   // "TASK_DELAY", "LOW_DURATION", "GEOFENCE_BREACH", "IDLE"
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id])
  taskId    Int?
  task      Task?    @relation(fields: [taskId], references: [id])
  message   String
  severity  String   // "LOW", "MEDIUM", "HIGH", "CRITICAL"
  timestamp DateTime @default(now())
  resolved  Boolean  @default(false)
}

model Visit {
  id           Int      @id @default(autoincrement())
  userId       Int
  user         User     @relation(fields: [userId], references: [id])
  customerName String?
  purpose      String
  notes        String?
  imageUrl     String?
  lat          Float
  lng          Float
  timestamp    DateTime @default(now())
  createdAt    DateTime @default(now())
}

model Media {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  taskId    Int?
  task      Task?    @relation(fields: [taskId], references: [id])
  fileUrl   String
  type      String   // "image" or "video"
  lat       Float?
  lng       Float?
  verified  Boolean  @default(false)
  verifiedAt DateTime?
  timestamp DateTime @default(now())
  createdAt DateTime @default(now())
}

model Location {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  lat       Float
  lng       Float
  timestamp DateTime @default(now())
}

model Alert {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  type      String   // e.g., "GEOFENCE_BREACH"
  message   String
  severity  String   // "LOW", "MEDIUM", "HIGH", "CRITICAL"
  resolved  Boolean  @default(false)
  timestamp DateTime @default(now())
  createdAt DateTime @default(now())
}
